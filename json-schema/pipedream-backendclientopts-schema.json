{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BackendClientOpts",
  "title": "BackendClientOpts",
  "type": "object",
  "description": "Options for creating a server-side client",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "The client ID for authentication"
    },
    "client_secret": {
      "type": "string",
      "description": "The client secret for authentication"
    },
    "api_url": {
      "type": "string",
      "description": "The API URL to use"
    },
    "scope": {
      "type": "string",
      "description": "Optional space-separated scopes for the access token. Defaults to `*`."
    }
  }
}