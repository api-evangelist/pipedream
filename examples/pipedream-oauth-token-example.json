{
  "request": {
    "method": "POST",
    "url": "https://api.pipedream.com/v1/oauth/token",
    "headers": {
      "Content-Type": "application/json"
    },
    "body": {
      "grant_type": "client_credentials",
      "client_id": "cid_xxx",
      "client_secret": "csec_xxx"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "access_token": "pd_oauth_xxx",
      "token_type": "Bearer",
      "expires_in": 3600
    }
  }
}